# Скопируйте этот файл в .env и замените значения на свои:
#   copy .env_example .env

# Обязательно: секретный ключ Django (сгенерируйте новый для продакшена)
DJANGO_SECRET_KEY=your-secret-key-here

# Режим отладки: True для разработки, False для продакшена
DJANGO_DEBUG=True

# Разрешённые хосты через запятую
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (если используете Docker Compose)
POSTGRES_DB=team_finder
POSTGRES_USER=team_finder
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
